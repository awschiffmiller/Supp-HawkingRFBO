{"time_format": "hh:mm:ss", "project_date": "", "project_name": "", "project_description": "", "project_format_version": "7.0", "subjects_conf": {}, "behaviors_conf": {"0": {"type": "Point event", "key": "0", "code": "ab0rt dive", "description": "horizon becomes roughly horizontal before entering water/landing/catching prey and bird resumes level flight", "color": "#900048", "category": "position", "modifiers": "", "excluded": "Dive", "coding map": ""}, "1": {"type": "State event", "key": "a", "code": "Airborne", "description": "soaring and flapping flight, dives", "color": "#ffff00", "category": "position", "modifiers": "", "excluded": "unknownState,Sitting,Underwater", "coding map": ""}, "2": {"type": "Point event", "key": "b", "code": "other Birds present", "description": "summary: estimated number of other birds visible over the previous 30 seconds (900 frames), species and behaviors exhibited, distance to nearest bird in preceeding 30 seconds", "color": "#ffd607", "category": "view", "modifiers": {"0": {"name": "estimated number", "description": "estimated number over preceeding 30 seconds", "type": 2, "values": []}, "1": {"name": "species present", "description": "select all species presen, specify Sula sp in comments when possible", "type": 1, "values": ["RFBO (r)", "booby- Sula sp (b)", "other (o)", "unknown (u)"]}, "2": {"name": "group behaviors", "description": "behaviors exhibited", "type": 1, "values": ["flying (f)", "diving (d)", "sitting (s)", "other (0)", "pile (p)"]}, "3": {"name": "distance to nearest birds", "description": "", "type": 0, "values": ["close - well defined body and movements (1)", "mid distance - shape and movement visible (2)", "far-moving speck or lines (3)"]}, "4": {"name": "most comon distance to other birds", "description": "", "type": 0, "values": ["close (4)", "mid (5)", "far (6)"]}}, "excluded": "obscured", "coding map": ""}, "3": {"type": "Point event", "key": "c", "code": "prey Capture", "description": "", "color": "#2ed9e8", "category": "position", "modifiers": {"0": {"name": "type", "description": "", "type": 0, "values": ["aborted plunge dive (a)", "type 1: plunge dive INTO water- fully submerged even only briefly (1)", "type 2: plunge dive to SURFACE of water- never subnerged but some splashing or washing of water (2)", "type 3: mid-air pursuit of prey (3)", "other: e.g. shallow angle water entry (o)"]}, "1": {"name": "Success", "description": "", "type": 0, "values": ["Successful (s)", "Failed (f)", "Unknown (u)", "aborted type 3 (a)"]}, "2": {"name": "bird/dabbling/dipping", "description": "", "type": 0, "values": ["dipping or dabbling after PCA (d)", "OTHER individual (x)", "shallow entry (e)"]}}, "excluded": "", "coding map": ""}, "4": {"type": "State event", "key": "d", "code": "Dive", "description": "turns sharply, horizon bent/vertical in frame, view mostly or fully of ocean surface. Ends with an abrupt landing after a dive (water splashes usually visible), or breaking surface of water after being submerged", "color": "#a700a7", "category": "position", "modifiers": "", "excluded": "unknownState,Sitting", "coding map": ""}, "5": {"type": "Point event", "key": "e", "code": "Eye/bill visible", "description": "Note when beak AND eye is present, as a possible proxy for scanning behavior", "color": "#2157ad", "category": "view", "modifiers": "", "excluded": "obscured", "coding map": ""}, "6": {"type": "State event", "key": "f", "code": "fish storm!", "description": "large number (>10) of flying fish flying at once and for some sustained time", "color": "#418b96", "category": "view", "modifiers": "", "excluded": "Underwater,obscured", "coding map": ""}, "7": {"type": "Point event", "key": "h", "code": "splasH", "description": "see a splash on water surface but can\u2019t identify source (marine pred or other diving bird)", "color": "#ffaaff", "category": "view", "modifiers": "", "excluded": "Underwater", "coding map": ""}, "8": {"type": "Point event", "key": "i", "code": "Identifiable/individual birds", "description": "Reserved for events when bird is doing something interesting ( diving, sitting, combat, taking off, flying interaction (collision/avoidance,parallel travel or possible antagonism). Can diferentiate wings/ head from body.", "color": "#ffb011", "category": "view", "modifiers": {"0": {"name": "number", "description": "", "type": 2, "values": []}, "1": {"name": "species", "description": "", "type": 0, "values": ["RFBO (r)", "booby- Sula sp (b)", "brown noddy (n)", "Fairy tern (t)", "other (o)", "unkown (u)", "sooty tern (s)"]}, "2": {"name": "age", "description": "", "type": 0, "values": ["adult (a)", "juvenile (j)", "unkown (y)"]}, "3": {"name": "behavior", "description": "", "type": 0, "values": ["diving (d)", "sitting (s)", "combat/tussle/aggression (c)", "takeoff (t)", "landing (l)", "parallel flight (p)", "cross paths (x)", "flying: other (f)"]}}, "excluded": "unknownState,obscured", "coding map": ""}, "9": {"type": "Point event", "key": "l", "code": "Landing", "description": "head drops out of view of frame (close to water), then raises to block view", "color": "#aaf78a", "category": "position", "modifiers": "", "excluded": "Airborne", "coding map": ""}, "10": {"type": "Point event", "key": "m", "code": "Marine predator", "description": "marine predator: tuna, dolphin, shark etc", "color": "#ff878d", "category": "view", "modifiers": {"0": {"name": "type", "description": "", "type": 0, "values": ["tuna (t)", "dolphin (d)", "shark (s)", "unknown (u)"]}}, "excluded": "obscured", "coding map": ""}, "11": {"type": "Point event", "key": "o", "code": "unidentified Object", "description": "", "color": "#ffc6ce", "category": "view", "modifiers": "", "excluded": "", "coding map": ""}, "12": {"type": "Point event", "key": "p", "code": "Prey", "description": "note type if identifyable in comments", "color": "#26b1be", "category": "view", "modifiers": "", "excluded": "obscured", "coding map": ""}, "13": {"type": "State event", "key": "q", "code": "unknownState", "description": "view obscured but movement and lighting changes indicate unknown activity. brief glimpses of blue that might be either sky or water may apear", "color": "#6d8473", "category": "position", "modifiers": "", "excluded": "Airborne,Dive,Sitting,Underwater", "coding map": ""}, "14": {"type": "State event", "key": "s", "code": "Sitting", "description": "view almost certainly obscured, but consitent. post landing sequence", "color": "#aaaaff", "category": "position", "modifiers": "", "excluded": "Airborne,Dive,unknownState", "coding map": ""}, "15": {"type": "Point event", "key": "t", "code": "Takeoff", "description": "tremors from wingbeats/running as view becomes less obscured", "color": "#acff85", "category": "position", "modifiers": "", "excluded": "Dive,unknownState,Sitting,Underwater", "coding map": ""}, "16": {"type": "State event", "key": "u", "code": "Underwater", "description": "view is blue, bubbles, or underside of water surface often visible", "color": "#026ba3", "category": "position", "modifiers": "", "excluded": "Airborne,fish storm!,unknownState", "coding map": ""}, "17": {"type": "State event", "key": "w", "code": "weather notes", "description": "weather conditions affecting visibility and interpretation", "color": "#fffccf", "category": "", "modifiers": {"0": {"name": "sky/clouds", "description": "", "type": 0, "values": ["clear (c)", "light partial clouds (l)", "heavy partial clouds (h)", "overcast - solid cloud layer (o)", "0ther (0)"]}, "1": {"name": "weather/visibility", "description": "", "type": 1, "values": ["rain (r)", "fog (f)", "sun glare (g)"]}, "2": {"name": "Beaufort sea state", "description": "wind speed/water roughness", "type": 1, "values": ["0 - glassy (0)", "1 - ripples no foam (1)", "2 - small wavelets glassy crests not breaking (2)", "3 - large wavelets crests breaking some scttered whitecaps (3)", "4 - small to moderate waves numerous whitecaps (4)", "5 - moderate waves many whitecaps some spray (5)", "6+ - large waves whitecaps foam spray (6)"]}}, "excluded": "", "coding map": ""}, "18": {"type": "State event", "key": "x", "code": "obscured", "description": "Can\u2019t identify details or activities", "color": "#393939", "category": "view", "modifiers": {"0": {"name": "by", "description": "what is obscuring the lens", "type": 0, "values": ["feathers (f)", "blurry/wet (b)", "unknown/other (u)"]}}, "excluded": "fish storm!,partially obscured", "coding map": ""}, "19": {"type": "State event", "key": "z", "code": "partially obscured", "description": "Can identify some activity to be coded (e.g. 'airborne') despite details of surroundings being obscured", "color": "#868686", "category": "view", "modifiers": {"0": {"name": "by", "description": "", "type": 0, "values": ["feathers (f)", "blurry/water (b)", "unknown/other (u)"]}}, "excluded": "obscured", "coding map": ""}}, "observations": {}, "behavioral_categories": ["position", "view"], "behavioral_categories_config": {}, "independent_variables": {}, "coding_map": {}, "behaviors_coding_map": [], "converters": {}}